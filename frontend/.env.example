# Required: backend root including /api prefix (examples below)
VITE_API_BASE_URL=http://localhost:3010/api

# Production: your deployed API URL (no trailing slash on /api unless your server expects it)
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# Optional: canonical & Open Graph URLs in production SPA
# VITE_SITE_URL=https://www.yourdomain.com
